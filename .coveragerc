[run]
source = plugins
branch = True
relative_files = True
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    .venv/*

[report]
show_missing = True
skip_covered = False
precision = 1
fail_under = 90
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
